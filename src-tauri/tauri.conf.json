{
  "$schema": "https://raw.githubusercontent.com/nicr9/tauri-2-workspace/refs/heads/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "Swavigator",
  "version": "0.5.1",
  "identifier": "com.strattenwaldt.swavigator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Developer ID Application: Baobab Group LLC (D4X8TSBQJC)",
      "minimumSystemVersion": "12.0"
    },
    "category": "DeveloperTool",
    "shortDescription": "A macOS workspace manager with space labeling and navigation.",
    "longDescription": "Swavigator lets you label, navigate, and manage macOS Spaces and windows from a compact floating panel. Features include app launcher groups, global hotkeys, and multi-display awareness."
  }
}