<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Disable app sandbox — required for Accessibility API, private CGS APIs,
         global shortcuts, child processes (Swift scripts), and Dock manipulation. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Hardened-runtime exceptions needed by the WKWebView engine and Swift child processes. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
